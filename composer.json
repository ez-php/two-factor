{
    "name": "ez-php/two-factor",
    "version": "1.6.1",
    "description": "Two-factor authentication module for the ez-php framework — RFC 6238 TOTP, QR code URLs, backup codes, and HTTP middleware",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Andreas Uretschnig",
            "email": "andreas.uretschnig@gmail.com"
        }
    ],
    "keywords": [
        "two-factor",
        "2fa",
        "totp",
        "otp",
        "authentication",
        "security",
        "php",
        "framework",
        "ez-php"
    ],
    "homepage": "https://github.com/ez-php/two-factor",
    "support": {
        "issues": "https://github.com/ez-php/two-factor/issues",
        "source": "https://github.com/ez-php/two-factor"
    },
    "require": {
        "php": "^8.5",
        "ez-php/contracts": "^1.0",
        "ez-php/http": "^1.0",
        "ez-php/auth": "^1.0"
    },
    "require-dev": {
        "ez-php/docker": "^1.0",
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "EzPhp\\TwoFactor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "test": "phpunit",
        "full": "composer analyse && composer cs && composer test"
    }
}
